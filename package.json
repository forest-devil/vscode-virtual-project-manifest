{
	"name": "sub-project-focus",
	"displayName": "%plugin.displayName%",
	"description": "A manifest-based sub project view with transient file tracking and LLM-ready merging.",
	"version": "3.1.5",
	"icon": "icon.png",
	"publisher": "forest-devil",
	"repository": "github:forst-devil/vscode-sub-project-focus",
	"main": "./extension.js",
	"engines": {
		"vscode": "^1.70.0"
	},
	"activationEvents": [
		"onView:sub-project-explorer"
	],
	"contributes": {
		"views": {
			"explorer": [
				{
					"id": "sub-project-explorer",
					"name": "%view.name%",
					"dragAndDropController": true
				}
			]
		},
		"commands": [
			{
				"command": "sub-project-focus.refresh",
				"title": "%command.refresh%",
				"icon": "$(refresh)",
				"category": "%view.name%"
			},
			{
				"command": "sub-project-focus.merge",
				"title": "%command.merge%",
				"icon": "$(combine)",
				"category": "%view.name%"
			},
			{
				"command": "sub-project-focus.add",
				"title": "%command.add%",
				"icon": "$(add)",
				"category": "%view.name%"
			},
			{
				"command": "sub-project-focus.init",
				"title": "%command.init%",
				"icon": "$(file-add)",
				"category": "%view.name%"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "sub-project-focus.refresh",
					"group": "navigation@1",
					"when": "view == sub-project-explorer"
				},
				{
					"command": "sub-project-focus.merge",
					"group": "navigation@2",
					"when": "view == sub-project-explorer"
				}
			],
			"view/item/context": [
				{
					"command": "sub-project-focus.add",
					"when": "(viewItem == unmatchedFile || viewItem == unmatchedFolder)",
					"group": "navigation@3"
				}
			]
		},
		"languages": [
			{
				"id": "ini",
				"filenames": [
					"MANIFEST.lst"
				]
			}
		],
		"configurationDefaults": {
			"workbench.colorCustomizations": {
				"sideBarSectionHeader.border": "#088080cc",
				"sideBarSectionHeader.background": "#044040cc",
				"sideBarSectionHeader.foreground": "#cccccccc",
				"activityBar.border": "#ffffff22"
			}
		}
	}
}