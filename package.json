{
	"name": "virtual-project-manifest",
	"displayName": "%plugin.displayName%",
	"description": "A manifest-based virtual project view with transient file tracking and LLM-ready merging.",
	"version": "3.1.2",
	"publisher": "forest-devil",
	"repository": "github:forst-devil/vscode-virtual-project-manifest",
	"main": "./extension.js",
	"engines": {
		"vscode": "^1.70.0"
	},
	"activationEvents": [
		"onView:manifest-explorer"
	],
	"contributes": {
		"views": {
			"explorer": [
				{
					"id": "manifest-explorer",
					"name": "%view.name%",
					"dragAndDropController": true
				}
			]
		},
		"commands": [
			{
				"command": "virtual-project-manifest.refresh",
				"title": "%command.refresh%",
				"icon": "$(refresh)"
			},
			{
				"command": "virtual-project-manifest.merge",
				"title": "%command.merge%",
				"icon": "$(combine)"
			},
			{
				"command": "virtual-project-manifest.add",
				"title": "%command.add%",
				"icon": "$(add)"
			},
			{
				"command": "virtual-project-manifest.init",
				"title": "%command.init%",
				"icon": "$(file-add)"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "virtual-project-manifest.refresh",
					"group": "navigation@1",
					"when": "view == manifest-explorer"
				},
				{
					"command": "virtual-project-manifest.merge",
					"group": "navigation@2",
					"when": "view == manifest-explorer"
				}
			],
			"view/item/context": [
				{
					"command": "virtual-project-manifest.add",
					"when": "(viewItem == unmatchedFile || viewItem == unmatchedFolder)",
					"group": "navigation@3"
				}
			]
		},
		"languages": [
			{
				"id": "ini",
				"filenames": ["MANIFEST.lst"]
			}
		],
		"configurationDefaults": {
			"workbench.colorCustomizations": {
				"sideBarSectionHeader.border": "#088080cc",
				"sideBarSectionHeader.background": "#044040cc",
				"sideBarSectionHeader.foreground": "#cccccccc",
				"activityBar.border": "#ffffff22"
			}
		}
	}
}